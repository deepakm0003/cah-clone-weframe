{
  "name": "cah-backend",
  "version": "1.0.0",
  "description": "Medusa.js backend for Cards Against Humanity clone",
  "scripts": {
    "build": "cross-env NODE_ENV=production medusa build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=400 medusa start",
    "dev": "medusa dev",
    "seed": "medusa db:migrate && medusa exec ./src/scripts/seed.ts"
  },
  "dependencies": {
    "@medusajs/admin-bundler": "^2.4.0",
    "@medusajs/cli": "^2.4.0",
    "@medusajs/dashboard": "^2.4.0",
    "@medusajs/framework": "^2.4.0",
    "@medusajs/medusa": "^2.4.0",
    "awilix": "^8.0.1",
    "cross-env": "^7.0.3",
    "pg": "^8.11.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/core": "^11.1.5",
    "@types/node": "^20.14.14",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

