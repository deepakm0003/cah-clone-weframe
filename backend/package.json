{
  "name": "cah-backend",
  "version": "1.0.0",
  "description": "Medusa.js backend for Cards Against Humanity clone",
  "scripts": {
    "clean": "cross-env rimraf dist",
    "build": "cross-env npm run clean && npm run build:server",
    "build:server": "cross-env medusa build",
    "start": "cross-env medusa start",
    "seed": "cross-env medusa db:migrate && medusa exec ./src/scripts/seed.ts",
    "dev": "cross-env medusa dev",
    "db:migrate": "cross-env medusa db:migrate"
  },
  "dependencies": {
    "@medusajs/medusa": "^2.4.0",
    "@medusajs/framework": "^2.4.0",
    "@medusajs/utils": "^2.4.0",
    "@medusajs/dashboard": "^2.4.0",
    "@medusajs/fulfillment-manual": "^2.4.0",
    "@medusajs/payment-manual": "^2.4.0",
    "@medusajs/stock-location": "^2.4.0",
    "@mikro-orm/core": "^6.3.13",
    "awilix": "^8.0.1",
    "cross-env": "^7.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "typescript": "^5.5.4"
  }
}
